# Pacific Basin BI Dashboard — Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local to git.

# Supabase — required for HK Marine voyage history persistence
# Without these, HK Marine still works (live XML fetch) but data isn't stored
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# AISStream — for future AIS real-time vessel position map (not yet integrated)
# Get a free key at: https://aisstream.io/
AISSTREAM_API_KEY=
